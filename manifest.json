{
  "manifest_version": 3,
  "name": "PopoutPlayer",
  "version": "1.5.30",
  "description": "Pop videos into separate windows — unlimited at once — with full player controls",
  "permissions": ["activeTab", "tabs", "windows", "scripting"],
  "action": {
    "default_title": "Pop out the largest video (unlimited windows)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/content.js"],
    "css": ["content/content.css"],
    "run_at": "document_idle",
    "all_frames": true
  }],
  "web_accessible_resources": [{
    "resources": ["player/player.css", "icons/*"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
