{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git push 2>/dev/null || true",
            "if": "Bash(git commit*)",
            "statusMessage": "Pushing to remote..."
          },
          {
            "type": "command",
            "command": "git fetch origin 2>/dev/null && LOCAL=$(git rev-parse @ 2>/dev/null) && REMOTE=$(git rev-parse @{u} 2>/dev/null) && [ \"$LOCAL\" != \"$REMOTE\" ] && git pull 2>/dev/null || true",
            "if": "Bash(git push*)",
            "statusMessage": "Syncing with remote..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/validate-extension.mjs\"",
            "statusMessage": "Validating PopoutPlayer extension..."
          }
        ]
      }
    ]
  }
}
