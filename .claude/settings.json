{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git push 2>/dev/null || true",
            "if": "Bash(git commit*)",
            "statusMessage": "Pushing to remote..."
          }
        ]
      }
    ]
  }
}
